# =========================
# Environment / runtime mode
# =========================
APP_NAME=mbsrn
APP_ENV=local
ENVIRONMENT=development

# CI/CD deploy secret and workflow-input naming is documented in:
# docs/deployment-configuration-contract.md
# This file is for application runtime configuration values only.

# Example local SQLite value.
# APP_ENV is authoritative for database localhost safety:
# localhost is allowed only when APP_ENV is local/dev/development/test/ci.
# APP_ENV=production requires DATABASE_URL and rejects localhost.
# Unknown or unset APP_ENV also rejects localhost.
# Production sidecar exception: localhost is allowed only when DB_CONNECTION_MODE=cloudsql_proxy.
# deploy-prod preflight and runtime enforce the same rule.
# deploy-gke preflight uses the same validator; default mode is direct unless overridden.
# In local/dev/test/ci only, DATABASE_URL may fall back to a localhost Postgres default.
# Production examples:
# DATABASE_URL=postgresql+psycopg://user:pass@db.example.com:5432/dbname
# DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance
DATABASE_URL=sqlite:///./local.db
# DB_CONNECTION_MODE=direct            # direct (default) | cloudsql_proxy
# Keep Alembic as the default schema authority for local development.
# Set to true only for disposable local experiments where migration history is intentionally bypassed.
DB_AUTO_CREATE_LOCAL=false

# =========================
# App/backend URL notes
# =========================
# No APP_BASE_URL setting is currently read by backend config.
# API callback URLs are configured via GOOGLE_BUSINESS_PROFILE_REDIRECT_URI below.

# =========================
# Frontend (Operator UI) reference values
# =========================
# The Next.js UI uses frontend/operator-ui/.env.local.
# These are listed here for one-place operator reference.
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oidc-client-id.apps.googleusercontent.com

# =========================
# CORS + security headers
# =========================
# API_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SECURITY_HEADERS_ENABLED=true
# SECURITY_HEADERS_HSTS_ENABLED=false
# SECURITY_HEADERS_HSTS_MAX_AGE_SECONDS=31536000

# =========================
# Authentication / session
# =========================
GOOGLE_AUTH_ENABLED=false
# GOOGLE_OIDC_CLIENT_ID=your-google-oidc-client-id.apps.googleusercontent.com
# Optional fallback source for GOOGLE_OAUTH_CLIENT_SECRET if GOOGLE_OAUTH_CLIENT_SECRET is not set:
# GOOGLE_OIDC_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_OIDC_REQUIRE_EMAIL_VERIFIED=true
GOOGLE_OIDC_TIMEOUT_SECONDS=5

# Required when GOOGLE_AUTH_ENABLED=true:
# APP_SESSION_SECRET=replace-with-long-random-secret
# APP_SESSION_ISSUER=mbsrn-console
# APP_SESSION_AUDIENCE=mbsrn-api
# APP_SESSION_ALGORITHM=HS256
APP_SESSION_TTL_SECONDS=3600
APP_SESSION_REFRESH_TTL_SECONDS=2592000

# =========================
# Google Business Profile OAuth (separate from Google login)
# =========================
# GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# GOOGLE_OAUTH_AUTHORIZATION_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
# GOOGLE_OAUTH_REVOKE_URL=https://oauth2.googleapis.com/revoke
# GOOGLE_OAUTH_TIMEOUT_SECONDS=10

# Must match Google OAuth redirect configuration:
# GOOGLE_BUSINESS_PROFILE_REDIRECT_URI=https://mbsrn.example.com/api/integrations/google/business-profile/connect/callback
GOOGLE_BUSINESS_PROFILE_STATE_TTL_SECONDS=600
GOOGLE_OAUTH_REFRESH_SKEW_SECONDS=120

# GBP API endpoint overrides (defaults target Google APIs):
# GOOGLE_BUSINESS_PROFILE_ACCOUNT_API_BASE_URL=https://mybusinessaccountmanagement.googleapis.com
# GOOGLE_BUSINESS_PROFILE_BUSINESS_INFORMATION_API_BASE_URL=https://mybusinessbusinessinformation.googleapis.com
# GOOGLE_BUSINESS_PROFILE_VERIFICATIONS_API_BASE_URL=https://mybusinessverifications.googleapis.com
# GOOGLE_BUSINESS_PROFILE_API_TIMEOUT_SECONDS=10
# Google Places seed discovery for SEO competitor generation (seed layer only):
# GOOGLE_PLACES_API_KEY=your-google-places-api-key
# GOOGLE_PLACES_API_BASE_URL=https://places.googleapis.com/v1
# GOOGLE_PLACES_API_TIMEOUT_SECONDS=8
# GOOGLE_PLACES_SEED_MAX_CANDIDATES=8
# GOOGLE_PLACES_SEED_QUERY_LIMIT=5
# Search Console read-only measurement:
# Search Console property URLs are configured per-site via site settings (not app-global env).
# Optional service-account JSON credentials blob; when omitted, runtime ADC is used.
# SEARCH_CONSOLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# SEARCH_CONSOLE_USE_MOCK_PROVIDER=false
# SEARCH_CONSOLE_TIMEOUT_SECONDS=10
# SEARCH_CONSOLE_PERIOD_DAYS=7
# SEARCH_CONSOLE_TOP_PAGES_LIMIT=5
# SEARCH_CONSOLE_TOP_QUERIES_LIMIT=3
# Admin GCP Logs Query proxy (uses runtime ADC attached service account):
# Expected project-id format: lowercase GCP project id, e.g. my-prod-project-123
# Configure this in deployed API runtime:
# GCP_PROJECT_ID=my-gcp-project-id
# GCP_LOGGING_API_TIMEOUT_SECONDS=10
# Runtime attached service account must have Cloud Logging read access
# (logging.logEntries.list / Logs Viewer or equivalent role on the configured project).

# =========================
# Provider token encryption (keyring + active version)
# =========================
# Active write key version.
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY_VERSION=v1

# Keyring JSON (required for rotation/fail-closed decrypt by stored token_key_version).
# Keep active + legacy versions during rotation windows.
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEYS_JSON={"v1":"active-key-material","v0":"legacy-key-material"}

# Legacy single-key fallback only when keyring JSON is omitted.
# GOOGLE_OAUTH_TOKEN_ENCRYPTION_SECRET=replace-with-long-random-secret

# =========================
# API credential hashing
# =========================
# Required in production.
# API_TOKEN_HASH_PEPPER=replace-with-long-random-secret
# ALLOW_LEGACY_TOKEN_HASH_FALLBACK=false

# =========================
# Redis / session / rate limit backends
# =========================
# Kubernetes deploy manifests set REDIS_URL to the internal Redis service.
# The values below are primarily for local/dev runtime outside Kubernetes.
# Local/dev/test defaults (single-process-safe, not production-safe):
# REDIS_URL=redis://localhost:6379/0
# SESSION_STATE_BACKEND=auto   # auto | inmemory | redis
# SESSION_STATE_FAIL_OPEN=true
# SESSION_STATE_ALLOW_INMEMORY_FALLBACK=true
# In-memory session fallback is acceptable for local/dev/test only.
# It is unsafe for multi-replica production because state is process-local.

RATE_LIMIT_ENABLED=true
# RATE_LIMIT_BACKEND=auto      # auto | inmemory | redis
# RATE_LIMIT_FAIL_OPEN=true
AUTH_RATE_LIMIT_REQUESTS=60
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_REQUESTS=20
ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# Pilot/prod recommended posture:
# Redis-backed shared session state is required for correctness in multi-replica production.
# Unsafe production combination: REDIS_URL unset + SESSION_STATE_BACKEND=auto + SESSION_STATE_ALLOW_INMEMORY_FALLBACK=true
# RATE_LIMIT_BACKEND=redis
# SESSION_STATE_BACKEND=redis
# RATE_LIMIT_FAIL_OPEN=false
# SESSION_STATE_FAIL_OPEN=false
# SESSION_STATE_ALLOW_INMEMORY_FALLBACK=false

# =========================
# Notification providers
# =========================
SMS_PROVIDER=mock
EMAIL_PROVIDER=mock
NOTIFICATION_TIMEOUT_SECONDS=10

# =========================
# AI competitor profile generation
# =========================
AI_PROVIDER_NAME=openai
AI_MODEL_NAME=gpt-4o-mini
AI_TIMEOUT_VALUE=30
# Eval harness safety guard (non-production only).
# Real-provider eval requires BOTH this flag and CLI --mode real.
AI_EVAL_ALLOW_REAL_PROVIDER=false
AI_PROMPT_TEXT_COMPETITOR=
AI_PROMPT_TEXT_RECOMMENDATIONS=
# DEPRECATED: fallback used only when split prompt vars are unset.
# Production deploy manifests do not inject this legacy variable.
# AI_PROMPT_TEXT_RECOMMENDATION=
SEO_COMPETITOR_PROFILE_RAW_OUTPUT_RETENTION_DAYS=30
SEO_COMPETITOR_PROFILE_RUN_RETENTION_DAYS=180
SEO_COMPETITOR_PROFILE_REJECTED_DRAFT_RETENTION_DAYS=90
# AI_PROVIDER_API_KEY=sk-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Twilio (required when SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+13035550123

# SMTP (required when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=example-user
# SMTP_PASSWORD=example-pass
# SMTP_FROM_ADDRESS=noreply@example.com
# SMTP_USE_TLS=true
